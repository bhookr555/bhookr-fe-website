# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.production
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env
!.env.example

# Sensitive files
*.pem
*.key
*.p12
*.pfx
serviceAccountKey.json
firebase-adminsdk*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ESLint reports (generated)
eslint-report.json
eslint-*.json

# Test files (dev only)
test-*.js
