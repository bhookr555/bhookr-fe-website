# ============================================
# BHOOKR - Environment Variables Configuration
# ============================================
# 
# ⚠️ SECURITY CRITICAL:
# 1. Copy this file to .env.local and fill in your actual values
# 2. NEVER commit .env.local to version control (it's in .gitignore)
# 3. NEVER share credentials publicly or in screenshots
# 4. Rotate secrets immediately if accidentally exposed
# 5. Use different credentials for development/staging/production
#
# 📚 Documentation: See devFiles/FIREBASE_SETUP.md for detailed setup

# ============================================
# FIREBASE CLIENT CONFIGURATION (Required)
# ============================================
# Location: Firebase Console > Project Settings > General > Your apps
# https://console.firebase.google.com/project/YOUR-PROJECT/settings/general
#
# ℹ️ Note: NEXT_PUBLIC_* variables are exposed to the browser.
# This is SAFE for Firebase as it uses security rules for protection.
# These are NOT secret credentials - they're meant to be public.

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-REPLACE-WITH-YOUR-API-KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Optional: Firebase Analytics
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Firebase Realtime Database URL
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# ============================================
# GOOGLE SHEETS INTEGRATION (Required for Leads & Subscriptions)
# ============================================
# Location: See google-apps-scripts/DEPLOYMENT_GUIDE.md for setup instructions
# 
# After deploying your Google Apps Script web apps:
# 1. Deploy the leads-sheet-script.gs to get Leads Sheet URL
# 2. Deploy the subscriptions-sheet-script.gs to get Subscriptions Sheet URL
# 3. Copy the deployment URLs below
#
# Format: https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Leads Sheet - Tracks all form submissions (Step 7 completions)
NEXT_PUBLIC_LEADS_SHEET_URL=https://script.google.com/macros/s/YOUR_LEADS_DEPLOYMENT_ID/exec

# Subscriptions Sheet - Tracks successful payments only
NEXT_PUBLIC_SUBSCRIPTIONS_SHEET_URL=https://script.google.com/macros/s/YOUR_SUBSCRIPTIONS_DEPLOYMENT_ID/exec

# Orders Sheet - Tracks menu item orders (one-time meal orders)
NEXT_PUBLIC_ORDERS_SHEET_URL=https://script.google.com/macros/s/YOUR_ORDERS_DEPLOYMENT_ID/exec

# ============================================
# FIREBASE ADMIN SDK (Server-side ONLY)
# ============================================
# ⚠️ CRITICAL: These are SECRET server-side credentials
# Location: Firebase Console > Project Settings > Service Accounts
# https://console.firebase.google.com/project/YOUR-PROJECT/settings/serviceaccounts/adminsdk
# Click "Generate new private key" to download JSON file
#
# 🔒 SECURITY:
# - These credentials MUST be kept secret
# - They provide FULL admin access to your Firebase project
# - NEVER expose in client-side code or public repositories
# - Store securely using environment variables or secrets management
# - Rotate immediately if compromised

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# 📝 FIREBASE_PRIVATE_KEY Format Notes:
# - Keep the double quotes around the entire key
# - Newlines must be escaped as \n (not actual line breaks)
# - Copy from the downloaded JSON: "private_key" field
# - Example format: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ============================================
# PAYMENT GATEWAY - Razorpay Integration
# ============================================
# 🔒 SECURITY: These are SECRET credentials - Never commit real values
# 
# Get credentials from: https://dashboard.razorpay.com/app/keys
# - Test Mode: Keys start with rzp_test_
# - Live Mode: Keys start with rzp_live_
#
# ⚠️ Use DIFFERENT credentials for development and production
# 📚 Documentation: https://razorpay.com/docs/

# Required - Get from Razorpay Dashboard
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Optional - For webhook verification (get from Razorpay Dashboard > Webhooks)
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment: development | production | test
NODE_ENV=development

# Application Base URL (for redirects, emails, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# OPTIONAL EXTERNAL SERVICES
# ============================================

# Email Service (Resend)
# 🔒 SECURITY: Keep API keys secret
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@bhookr.com
RESEND_REPLY_TO=support@bhookr.com

# SMS Service (Twilio, AWS SNS, MSG91, etc.)
# 🔒 SECURITY: Keep credentials secret
# SMS_SERVICE_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
# SMS_SERVICE_AUTH_TOKEN=your_auth_token_here
# SMS_SERVICE_PHONE_NUMBER=+1234567890

# Error Tracking (Sentry, LogRocket, etc.)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Analytics (Google Analytics, Mixpanel, Amplitude, etc.)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ============================================
# 🔒 SECURITY BEST PRACTICES
# ============================================
#
# ✅ DO:
# - Use .env.local for local development (git-ignored)
# - Use platform secrets for production (Vercel, AWS, etc.)
# - Rotate credentials every 90 days
# - Use different credentials per environment
# - Enable 2FA on all service accounts
# - Monitor access logs regularly
# - Use secrets management tools (AWS Secrets Manager, HashiCorp Vault)
# - Implement principle of least privilege
#
# ❌ DON'T:
# - Commit .env.local or any .env file with real credentials
# - Share credentials via Slack, email, or messaging
# - Hardcode secrets in source code
# - Reuse credentials across environments
# - Store secrets in version control (even private repos)
# - Take screenshots containing credentials
# - Use production credentials in development
#
# 🚨 IF CREDENTIALS ARE EXPOSED:
# 1. Immediately rotate ALL compromised credentials
# 2. Review access logs for unauthorized activity
# 3. Update all environments with new credentials
# 4. Document the incident
# 5. Review security practices to prevent recurrence

# ============================================
# 📋 SETUP CHECKLIST
# ============================================
# [ ] Create Firebase project: https://console.firebase.google.com
# [ ] Enable Authentication methods (Email/Password, Google)
# [ ] Create Firestore Database (production mode)
# [ ] Set up Security Rules for Firestore and Storage
# [ ] Generate Firebase Admin SDK credentials (if needed)
# [ ] Copy this file to .env.local
# [ ] Fill in all required credentials
# [ ] Test authentication flow
# [ ] Verify .env.local is in .gitignore
# [ ] Set up production environment variables on hosting platform
# [ ] Enable monitoring and logging
# [ ] Document credential rotation schedule
#
# 📚 Detailed Documentation:
# - Firebase Setup: devFiles/FIREBASE_SETUP.md
# - Developer Guide: devFiles/DEVELOPER_GUIDE.md
# - Security Audit: devFiles/SECURITY_AUDIT_REPORT.md
